<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | <%= appName %></title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet" />
</head>
<body>

<nav class="navbar">
  <div class="nav-inner">
    <a href="<%= user ? '/dashboard' : '/' %>" class="nav-brand">
      <span class="crown-icon">&#x1F451;</span>
      <span>KOM Memorial</span>
    </a>
    <div class="nav-links">
      <% if (user) { %>
        <a href="/dashboard" class="nav-link">Dashboard</a>
        <a href="/koms/add" class="nav-link nav-cta">+ Add KOM</a>
        <form action="/logout" method="POST" class="inline">
          <button type="submit" class="nav-link nav-logout">Sign Out</button>
        </form>
      <% } else { %>
        <a href="/login" class="nav-link">Sign In</a>
        <a href="/register" class="nav-link nav-cta">Get Started</a>
      <% } %>
    </div>
  </div>
</nav>

<main class="main-content">
