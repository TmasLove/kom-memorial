# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=3000
NODE_ENV=development

# Session secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-secret

# PostgreSQL connection string
# For local dev: postgres://user:pass@localhost:5432/kom_memorial
# For Neon (Vercel): copy from Vercel dashboard → Storage → your DB → .env.local
DATABASE_URL=postgres://user:pass@localhost:5432/kom_memorial

# Vercel Blob token (for memorial image uploads)
# In Vercel dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# App branding (appears on generated memorial images)
APP_NAME=KOM Memorial
APP_URL=http://localhost:3000
